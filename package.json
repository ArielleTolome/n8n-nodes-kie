  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint 'nodes/**/*.ts' 'credentials/**/*.ts'",
    "lintfix": "eslint 'nodes/**/*.ts' 'credentials/**/*.ts' --fix",
    "prepublishOnly": "npm run build && npm run lint -s",
    "prepare": "npm run build",
    "test": "jest"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/Sora2Pro/Sora2Pro.node.js",
      "dist/nodes/Kling/Kling.node.js",
      "dist/nodes/Seedream/Seedream.node.js",
      "dist/nodes/Seedance/Seedance.node.js",
      "dist/nodes/Wan/Wan.node.js",
      "dist/nodes/Hailuo/Hailuo.node.js",
      "dist/nodes/GrokImagine/GrokImagine.node.js",
      "dist/nodes/Google/Google.node.js",
      "dist/nodes/Flux/Flux.node.js",
      "dist/nodes/Ideogram/Ideogram.node.js",
      "dist/nodes/Qwen/Qwen.node.js",
      "dist/nodes/ZImage/ZImage.node.js",
      "dist/nodes/Topaz/Topaz.node.js",
      "dist/nodes/Recraft/Recraft.node.js",
      "dist/nodes/GptImage15/GptImage15.node.js",
      "dist/nodes/FourOImage/FourOImage.node.js",
      "dist/nodes/Runway/Runway.node.js",
      "dist/nodes/Veo/Veo.node.js",
      "dist/nodes/Suno/Suno.node.js",
      "dist/nodes/ElevenLabs/ElevenLabs.node.js",
      "dist/nodes/InfineTalk/InfineTalk.node.js"
    ],
    "credentials": [
      "dist/credentials/KieApi.credentials.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^5.0.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "overrides": {
    "braces": "^3.0.3",
    "form-data": "^4.0.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^n8n-workflow$": "<rootDir>/node_modules/n8n-workflow"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "strict": false
          }
        }
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
